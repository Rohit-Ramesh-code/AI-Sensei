# ============================================================
# Project Sentinel -- Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ----- SNMP Configuration -----
# IP address of the Lexmark XC2235 printer
SNMP_HOST=192.168.1.100
# SNMP community string (default is 'public' for read-only access)
SNMP_COMMUNITY=public

# ----- SMTP Email Configuration -----
# SMTP server hostname
#   Gmail:          smtp.gmail.com        (requires App Password)
#   Outlook/O365:   smtp.office365.com    (requires SMTP AUTH enabled in account settings)
SMTP_HOST=smtp.gmail.com
# SMTP port — 587 for STARTTLS (recommended)
SMTP_PORT=587
# Your email address (used to log in and as the From address)
SMTP_USERNAME=you@gmail.com
# Gmail: use a 16-character App Password (NOT your regular password)
#   Generate at: https://myaccount.google.com/apppasswords
#   Requires 2-Step Verification to be enabled on your Google account
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
# Optional: override the From address (defaults to SMTP_USERNAME if not set)
# SMTP_FROM=sentinel@gmail.com

# ----- Alert Configuration -----
# Email address to receive toner alert notifications
ALERT_RECIPIENT=admin@example.com

# ----- Policy Guard Thresholds -----
# Minimum LLM confidence score to send an alert (0.0 - 1.0)
LLM_CONFIDENCE_THRESHOLD=0.7
# Toner level percentage below which a WARNING alert is triggered (0 - 100)
TONER_ALERT_THRESHOLD=20
# Toner level percentage below which a CRITICAL alert is triggered (0 - 100)
TONER_CRITICAL_THRESHOLD=10
# Maximum age of a poll result before it is considered stale (minutes)
STALE_THRESHOLD_MINUTES=120

# ----- Scheduling -----
# How often Sentinel polls the printer (minutes). Default: 60.
# Must be a positive integer. Invalid values cause a startup error.
POLL_INTERVAL_MINUTES=60

# ----- Development / Test Mode -----
# Set to 'true' to use hardcoded fixture data instead of querying the real printer
USE_MOCK_SNMP=false
# Set to 'true' to log emails to stdout instead of sending via SMTP
USE_MOCK_SMTP=false
# Set to 'true' to use mock LLM responses instead of calling OpenAI
USE_MOCK_LLM=false

# ----- Web Chat Authentication -----
# Secret key used to sign session cookies — use a long random string in production.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-me-with-a-long-random-string
# Username and password required to access the chat interface
CHAT_USERNAME=admin
CHAT_PASSWORD=change-me

# Seconds to wait for a single Ollama LLM response before falling back to the
# Random Forest confidence model. Keep this well below PIPELINE_TIMEOUT_SECONDS.
# Default: 20. Increase if your model is large and generation is consistently slow.
LLM_TIMEOUT_SECONDS=20

# ----- Web Chat Interface -----
# Port for the chat server (default: 5000)
CHAT_PORT=5000
# Base URL of the remote Ollama instance (must have llama3.1 pulled)
# Run 'ollama pull llama3.1' on the Ollama host before starting chat_server.py
OLLAMA_BASE_URL=http://192.168.1.200:11434
# Ollama model name for intent classification
OLLAMA_MODEL=llama3.1
