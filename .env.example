# ============================================================
# Project Sentinel -- Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ----- SNMP Configuration -----
# IP address of the Lexmark XC2235 printer
SNMP_HOST=192.168.1.100
# SNMP community string (default is 'public' for read-only access)
SNMP_COMMUNITY=public

# ----- Exchange / EWS Configuration -----
# Exchange server URL (e.g., https://mail.company.com/EWS/Exchange.asmx)
EWS_SERVER=https://mail.example.com/EWS/Exchange.asmx
# Exchange service account credentials
EWS_USERNAME=sentinel-service@example.com
EWS_PASSWORD=your-service-account-password
# Auth type: NTLM (on-prem default), BASIC, or MSAL (Office 365)
EWS_AUTH_TYPE=NTLM

# ----- Alert Configuration -----
# Email address to receive toner alert notifications
ALERT_RECIPIENT=admin@example.com

# ----- Policy Guard Thresholds -----
# Minimum LLM confidence score to send an alert (0.0 - 1.0)
LLM_CONFIDENCE_THRESHOLD=0.7
# Toner level percentage below which an alert is triggered (0 - 100)
TONER_ALERT_THRESHOLD=20

# ----- Development / Test Mode -----
# Set to 'true' to use hardcoded fixture data instead of querying the real printer
USE_MOCK_SNMP=false
# Set to 'true' to log emails to stdout instead of sending via Exchange
USE_MOCK_EWS=false
