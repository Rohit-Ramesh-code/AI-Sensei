# ============================================================
# Project Sentinel -- Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ----- SNMP Configuration -----
# IP address of the Lexmark XC2235 printer
SNMP_HOST=192.168.1.100
# SNMP community string (default is 'public' for read-only access)
SNMP_COMMUNITY=public

# ----- SMTP Email Configuration -----
# SMTP server hostname (smtp.office365.com for personal Outlook / Office 365)
SMTP_HOST=smtp.office365.com
# SMTP port — 587 for STARTTLS (recommended), 465 for SSL
SMTP_PORT=587
# Your Outlook email address (used to log in and as the From address)
SMTP_USERNAME=you@outlook.com
# Your Outlook password or App Password (recommended if MFA is enabled)
# To create an App Password: https://account.microsoft.com/security -> App passwords
SMTP_PASSWORD=your-outlook-password
# Optional: override the From address (defaults to SMTP_USERNAME if not set)
# SMTP_FROM=sentinel@outlook.com

# ----- Alert Configuration -----
# Email address to receive toner alert notifications
ALERT_RECIPIENT=admin@example.com

# ----- Policy Guard Thresholds -----
# Minimum LLM confidence score to send an alert (0.0 - 1.0)
LLM_CONFIDENCE_THRESHOLD=0.7
# Toner level percentage below which an alert is triggered (0 - 100)
TONER_ALERT_THRESHOLD=20

# ----- Development / Test Mode -----
# Set to 'true' to use hardcoded fixture data instead of querying the real printer
USE_MOCK_SNMP=false
# Set to 'true' to log emails to stdout instead of sending via SMTP
USE_MOCK_SMTP=false
